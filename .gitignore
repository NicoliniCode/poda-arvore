# Dependências Node
node_modules/
**/node_modules/

# Builds
dist/
build/
**/dist/
**/build/

# Variáveis de ambiente - não subir senhas
.env
.env.*
**/.env
**/.env.*

# Permitir arquivos de exemplo
!.env.example
!**/.env.example

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Uploads de arquivos do sistema
uploads/*
backend/uploads/*
frontend/uploads/*

# Manter pastas uploads vazias no Git, se existir .gitkeep
!uploads/.gitkeep
!backend/uploads/.gitkeep
!frontend/uploads/.gitkeep

# Banco/volumes locais
mysql_data/
**/mysql_data/
data/
**/data/
letsencrypt/
**/letsencrypt/

# Docker / chaves / certificados sensíveis
*.pem
*.key
*.crt

# Sistema operacional
.DS_Store
Thumbs.db

# VS Code opcional
.vscode/